{
  "name": "aicfo",
  "version": "0.1.0",
  "private": true,
  "description": "Aicfo - CFO-IA / Plataforma de gestão financeira inteligente para PMEs. Backend Node/TS+LangGraph operado pelo framework agent-governance-framework.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsup src --format esm --target node20 --clean",
    "start": "node --env-file=.env dist/server.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "eval:run": "tsx evals/run.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@langchain/langgraph": "^1.2.0",
    "@prisma/client": "^6.0.0",
    "bullmq": "^5.0.0",
    "fastify": "^5.0.0",
    "ioredis": "^5.0.0",
    "langfuse": "^3.38.0",
    "pino": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "prettier": "^3.0.0",
    "prisma": "^6.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^1.0.0"
  }
}
