# Anthropic (fallback)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Vertex AI (provider primário — dre-narrative, action-plan, anomaly/margin, normalization, clarity, classifier)
# Migrado de Google AI Studio (GOOGLE_API_KEY) em 2026-05-20 para LGPD — ADR-009.
# Dados ficam em southamerica-east1 (São Paulo).
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=southamerica-east1

# Auth — dois modos suportados:
# (1) DEV/local: caminho para o arquivo SA JSON
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# (2) PROD/Railway: SA JSON inline (escapado em uma linha). Tem precedência sobre (1).
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Modelo local (Fase 2 — ollama ou llama.cpp server)
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=qwen2.5:3b

# LangSmith (telemetria — C6, provedor canônico do Forge v0.22.0+)
# Implementação em src/observability/tracing.ts (provider-agnostic — wrapper LangSmith)
LANGSMITH_API_KEY=lsv2_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGSMITH_PROJECT=aicfo
LANGCHAIN_TRACING_V2=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com  # opcional — default já aponta para LangSmith cloud

# Postgres (Prisma)
# DEV: sem params de pool
DATABASE_URL=postgresql://aicfo:aicfo@localhost:5432/aicfo?schema=public
# PROD (Railway): adicionar connection_limit e pool_timeout para suportar múltiplos workers/réplicas
# DATABASE_URL=postgresql://user:pass@host:5432/db?schema=public&connection_limit=10&pool_timeout=20

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Server
PORT=3000
NODE_ENV=development

# Rate limiting (requisições por minuto por IP — global). Default: 100.
# Em prod com múltiplas réplicas, considerar redis-backed store (adicionar RATE_LIMIT_REDIS=true).
RATE_LIMIT_MAX=100

# Worker concurrency (jobs LLM simultâneos por tipo por instância).
# Em prod com Railway Scale (múltiplas réplicas), manter valores baixos — workers compartilham Redis.
# Aumentar só se tiver Redis com memória suficiente e rate limits LLM permitirem.
WORKER_CONCURRENCY_CLASSIFICATION=3
WORKER_CONCURRENCY_NARRATIVE=2
WORKER_CONCURRENCY_ACTION=2

# JWT (auth-tenant — Onda 0)
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRES_IN=7d

# Stripe (billing — Onda 0)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_LITE=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_BUSINESS=price_xxxxxxxxxxxxxxxxxxxxxxxx

# URL pública do frontend (usada nos redirects do Stripe e password reset)
APP_URL=http://localhost:5173

# CORS — origens permitidas (CSV). Default em dev permite Vite em :5173.
FRONTEND_ORIGIN=http://localhost:5173

# URL pública do backend (campo `servers` da spec OpenAPI). Vazio = http://localhost:$PORT.
PUBLIC_API_URL=

# Email transacional (password reset — Wave 2). Sem chave em dev, o link cai no log.
RESEND_API_KEY=
EMAIL_FROM=Aicfo <no-reply@aicfo.app>

# Forge bypass (auditado — usar com critério; default vazio = sem bypass)
ACME_FORGE_BYPASS=
