# Anthropic (fallback)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Vertex AI (provider primário — dre-narrative, action-plan, anomaly/margin, normalization, clarity, classifier)
# Migrado de Google AI Studio para Vertex (ADR-009). Região us-central1 porque o
# Gemini 2.5 não está em southamerica-east1 (ADR-019: transferência internacional
# com SCCs do Google DPA, Art. 33 LGPD; Vertex não treina com os dados).
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Auth — dois modos suportados:
# (1) DEV/local: caminho para o arquivo SA JSON
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# (2) PROD/Railway: SA JSON inline (escapado em uma linha). Tem precedência sobre (1).
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Modelo local (Fase 2 — ollama ou llama.cpp server)
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=qwen2.5:3b

# LangSmith (telemetria — C6, provedor canônico do Forge v0.22.0+)
# Implementação em src/observability/tracing.ts (provider-agnostic — wrapper LangSmith)
LANGSMITH_API_KEY=lsv2_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGSMITH_PROJECT=aicfo
LANGCHAIN_TRACING_V2=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com  # opcional — default já aponta para LangSmith cloud

# Postgres (Prisma)
# DEV: sem params de pool
DATABASE_URL=postgresql://aicfo:aicfo@localhost:5432/aicfo?schema=public
# PROD (Railway): adicionar connection_limit e pool_timeout para suportar múltiplos workers/réplicas
# DATABASE_URL=postgresql://user:pass@host:5432/db?schema=public&connection_limit=10&pool_timeout=20

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Server
PORT=3000
NODE_ENV=development

# Rate limiting (requisições por minuto por IP — global). Default: 100.
# Em ambiente Railway (RAILWAY_ENVIRONMENT setado + REDIS_URL), o store é Redis-backed
# automaticamente — compartilha o contador entre réplicas (sem isso, o limite efetivo
# seria N×max). Em dev (single instance) usa store in-memory. Ver src/http/rate-limit.ts.
RATE_LIMIT_MAX=100

# Worker concurrency (jobs simultâneos do grafo monthly-analysis por instância).
# Em prod com Railway Scale (múltiplas réplicas), manter valores baixos — workers compartilham Redis.
# Aumentar só se tiver Redis com memória suficiente e rate limits LLM permitirem.
# Pico de chamadas Vertex simultâneas ≈ este valor × MONTHLY_ANALYSIS_CHUNK_CONCURRENCY.
WORKER_CONCURRENCY_GRAPH=2

# Backpressure (Gate 1.2): teto de jobs pendentes (waiting+delayed) na fila de análise.
# Acima dele, /ingest que gera análise responde 503 (Retry-After) antes de parsear —
# protege Redis/memória sob burst de onboarding. Free tier (cashflow-only) não é afetado.
MAX_ANALYSIS_QUEUE_DEPTH=1000

# Orquestrador da análise mensal: LangGraph é o caminho ÚNICO — orquestra todos os
# agentes (classificação, DRE, narrativa, plano, QA). BullMQ é só fila/transporte.
# A cadeia BullMQ legada (jobs classification→dre-narrative→action-plan) foi REMOVIDA;
# rollback agora é git revert + deploy, não flag.

# JWT (auth-tenant — Onda 0)
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRES_IN=7d

# Stripe (billing — Onda 0)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_LITE=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_BUSINESS=price_xxxxxxxxxxxxxxxxxxxxxxxx

# WhatsApp (canal — Meta Cloud API)
# META_WEBHOOK_VERIFY_TOKEN: token do handshake GET do webhook (você define este valor)
# META_APP_SECRET: App Secret do app Meta — assina o webhook (X-Hub-Signature-256).
#   OBRIGATÓRIO: sem ele o POST /webhooks/whatsapp rejeita tudo (401, fail-closed).
META_WEBHOOK_VERIFY_TOKEN=replace-with-your-verify-token
META_APP_SECRET=replace-with-meta-app-secret

# WhatsApp — fluxo conversacional (LangGraph zero-token, PR #159)
# WHATSAPP_CONVERSATION_GRAPH_ENABLED: liga o fluxo conversacional. Precisa ser
#   exatamente "true". Off (default) → fluxo legado de menu numérico (handleMenu).
#   Setar por-ambiente no Railway exige redeploy para valer.
# WHATSAPP_CONVERSATION_SLM_ENABLED: libera o caminho SLM para explicar o último
#   resultado (consome tokens — impacta C3). Default off; só tem efeito com o grafo ligado.
WHATSAPP_CONVERSATION_GRAPH_ENABLED=false
WHATSAPP_CONVERSATION_SLM_ENABLED=false

# URL pública do frontend (usada nos redirects do Stripe e password reset)
APP_URL=http://localhost:5173

# CORS — origens permitidas (CSV). Default em dev permite Vite em :5173.
FRONTEND_ORIGIN=http://localhost:5173

# URL pública do backend (campo `servers` da spec OpenAPI). Vazio = http://localhost:$PORT.
PUBLIC_API_URL=

# Email transacional (password reset — Wave 2). Sem chave em dev, o link cai no log.
RESEND_API_KEY=
EMAIL_FROM=Aicfo <no-reply@aicfo.app>

# Forge bypass (auditado — usar com critério; default vazio = sem bypass)
ACME_FORGE_BYPASS=
